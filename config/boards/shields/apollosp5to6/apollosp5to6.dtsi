#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/mouse.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-nrf-vddh";
    };

    physical_layout0: physical_layout0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        keys = <&key_physical_attrs 100 100 100 25 0 0 0>    // [0,1]
             , <&key_physical_attrs 100 100 200 0 0 0 0>     // [0,2]
             , <&key_physical_attrs 100 100 300 (-25) 0 0 0> // [0,3]
             , <&key_physical_attrs 100 100 400 0 0 0 0>     // [0,4]
             , <&key_physical_attrs 100 100 500 25 0 0 0>    // [0,5]

             , <&key_physical_attrs 100 100 880 25 0 0 0>     // [0,8]
             , <&key_physical_attrs 100 100 980 0 0 0 0>      // [0,9]
             , <&key_physical_attrs 100 100 1080 (-25) 0 0 0> // [0,10]
             , <&key_physical_attrs 100 100 1180 0 0 0 0>     // [0,11]
             , <&key_physical_attrs 100 100 1280 25 0 0 0>    // [0,12]

             /* Row 1 */
             , <&key_physical_attrs 100 100 0 100 0 0 0>
             , <&key_physical_attrs 100 100 100 125 0 0 0>
             , <&key_physical_attrs 100 100 200 100 0 0 0>
             , <&key_physical_attrs 100 100 300 75 0 0 0>
             , <&key_physical_attrs 100 100 400 100 0 0 0>
             , <&key_physical_attrs 100 100 500 125 0 0 0>
//           , <&key_physical_attrs 100 100 615 125 0 0 0>

             , <&key_physical_attrs 100 100 765 125 0 0 0>
             , <&key_physical_attrs 100 100 880 125 0 0 0>
             , <&key_physical_attrs 100 100 980 100 0 0 0>
             , <&key_physical_attrs 100 100 1080 75 0 0 0>
             , <&key_physical_attrs 100 100 1180 100 0 0 0>
             , <&key_physical_attrs 100 100 1280 125 0 0 0>
             , <&key_physical_attrs 100 100 1380 100 0 0 0>

             /* Row 2 */
             , <&key_physical_attrs 100 100 0 200 0 0 0>
             , <&key_physical_attrs 100 100 100 225 0 0 0>
             , <&key_physical_attrs 100 100 200 200 0 0 0>
             , <&key_physical_attrs 100 100 300 175 0 0 0>
             , <&key_physical_attrs 100 100 400 200 0 0 0>
             , <&key_physical_attrs 100 100 500 225 0 0 0>
             , <&key_physical_attrs 100 100 615 225 0 0 0>

             , <&key_physical_attrs 100 100 765 225 0 0 0>
             , <&key_physical_attrs 100 100 880 225 0 0 0>
             , <&key_physical_attrs 100 100 980 200 0 0 0>
             , <&key_physical_attrs 100 100 1080 175 0 0 0>
             , <&key_physical_attrs 100 100 1180 200 0 0 0>
             , <&key_physical_attrs 100 100 1280 225 0 0 0>
             , <&key_physical_attrs 100 100 1380 200 0 0 0>

             /* Row 3 */
             , <&key_physical_attrs 100 100 0 300 0 0 0>
             , <&key_physical_attrs 100 100 100 325 0 0 0>
             , <&key_physical_attrs 100 100 200 300 0 0 0>
             , <&key_physical_attrs 100 100 300 275 0 0 0>
             , <&key_physical_attrs 100 100 400 300 0 0 0>
             , <&key_physical_attrs 100 100 500 325 0 0 0>
             , <&key_physical_attrs 100 100 600 325 0 0 0>

             , <&key_physical_attrs 100 100 880 325 0 0 0>
             , <&key_physical_attrs 100 100 980 300 0 0 0>
             , <&key_physical_attrs 100 100 1080 275 0 0 0>
             , <&key_physical_attrs 100 100 1180 300 0 0 0>
             , <&key_physical_attrs 100 100 1280 325 0 0 0>
             , <&key_physical_attrs 100 100 1380 300 0 0 0>

             /* Row 4: 親指 */
             /* 幅 高 X座標 Y座標 回転角 ラベルX ラベルY */
             , <&key_physical_attrs 100 100 0 400 0 0 0>
             , <&key_physical_attrs 100 100 100 425 0 0 0>
             , <&key_physical_attrs 100 100 200 400 0 0 0>
             , <&key_physical_attrs 100 100 300 450 (0) 0 0>
             , <&key_physical_attrs 100 100 410 455 (1000) 0 0>
             , <&key_physical_attrs 100 100 520 475 (2000) 0 0>
             , <&key_physical_attrs 100 100 630 515 (3000) 0 0>

             , <&key_physical_attrs 100 100 760 560 (-3000) 0 0>    // 565
             , <&key_physical_attrs 100 100 865 500 (-2000) 0 0>    // 515→520→500
             , <&key_physical_attrs 100 100 970 468 (-1000) 0 0>    // 475
             , <&key_physical_attrs 100 100 1080 450 (0) 0 0>;       // 450
    };

    default_transform: keymap_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <5>;
        map = <
                    RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                     RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)             RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)     RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)             RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6)     RC(4,7) RC(4,8) RC(4,9) RC(4,10)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
        row-gpios
            = <&gpio0 6  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio0 8  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio1 4  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio1 6  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };

    right_encoder: encoder_right {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        b-gpios = <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        steps = <24>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&right_encoder>;
        triggers-per-rotation = <20>;
    };
};
