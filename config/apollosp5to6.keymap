#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>
#define ZMK_POINTING_DEFAULT_SCRL_VAL 100

&msc {
        x-input-code = <INPUT_REL_HWHEEL>; // 横スクロールの定義
        y-input-code = <INPUT_REL_WHEEL>;  // 縦スクロールの定義
        time-to-max-speed-ms = <100>;      // 100〜300くらいが快適です
        acceleration-exponent = <3>;       // 0だと等速、1以上だと加速がつきます
};

/ {
        macros {
                // 画面ショット (Shift + Win + S)
                m_sshot: m_sshot {
                        compatible = "zmk,behavior-macro";
                        #binding-cells = <0>;
                        bindings
                                = <&macro_press &kp LSHFT &kp LGUI>
                                , <&macro_tap &kp S>
                                , <&macro_release &kp LSHFT &kp LGUI>;
                };

                // 画面ロック (Ctrl + Alt + Del)
                m_slock: m_slock {
                        compatible = "zmk,behavior-macro";
                        #binding-cells = <0>;
                        bindings
                                = <&macro_press &kp LCTRL &kp LALT>
                                , <&macro_tap &kp DEL>
                                , <&macro_release &kp LCTRL &kp LALT>;
                };
        };


        combos {
                compatible = "zmk,combos";
                // 1 + Q で BT0
                combo_bt0 {
                    timeout-ms = <50>;
                    key-positions = <0 11>;
                    bindings = <&bt BT_SEL 0>;
                    layers = <1>;
                };

                // 2 + W で BT1
                combo_bt1 {
                    timeout-ms = <50>;
                    key-positions = <1 12>;
                    bindings = <&bt BT_SEL 1>;
                    layers = <1>;
                };

                // 3 + E で BT2
                combo_bt2 {
                    timeout-ms = <50>;
                    key-positions = <2 13>;
                    bindings = <&bt BT_SEL 2>;
                    layers = <1>;
                };

                // 4 + R で BT3
                combo_bt3 {
                    timeout-ms = <50>;
                    key-positions = <3 14>;
                    bindings = <&bt BT_SEL 3>;
                    layers = <1>;
                };
        };

        behaviors {
                // 横スクロール
                scroll_left_right: behavior_sensor_rotate_mouse_wheel_left_right {
                        compatible = "zmk,behavior-sensor-rotate";
                        #sensor-binding-cells = <0>;
                        bindings = <&msc SCRL_RIGHT>, <&msc SCRL_LEFT>;
                        tap-ms = <50>;
                };
        };


/* 
 * ============================================================================
 *  JIS (Japanese) Layout Symbol Mapping with Modifiers for ZMK
 *  OS側が日本語配列(JIS)設定の時に、目的の記号を1つのキーで出すための設定
 *  参考: https://v0-3-branch.zmk.dev/docs/keymaps/list-of-keycodes#modifiers
 * ============================================================================
 *  Desired Symbol    ┃ ZMK Binding       ┃ Original Key on JIS Layout
 * -------------------┃-------------------┃------------------------------------
 *  ! (exclamation)   ┃ &kp LS(N1)        ┃ Shift + 1
 *  " (double quote)  ┃ &kp LS(N2)        ┃ Shift + 2
 *  # (hash / sharp)  ┃ &kp LS(N3)        ┃ Shift + 3
 *  $ (dollar)        ┃ &kp LS(N4)        ┃ Shift + 4
 *  % (percent)       ┃ &kp LS(N5)        ┃ Shift + 5
 *  & (ampersand)     ┃ &kp LS(N6)        ┃ Shift + 6
 *  ' (single quote)  ┃ &kp LS(N7)        ┃ Shift + 7
 *  ( (paren open)    ┃ &kp LS(N8)        ┃ Shift + 8
 *  ) (paren close)   ┃ &kp LS(N9)        ┃ Shift + 9
 *  ~ (tilde)         ┃ &kp LS(EQUAL)     ┃ Shift + ^
 *  ┃ (pipe)          ┃ &kp LS(INT3)      ┃ Shift + ￥
 *  + (plus)          ┃ &kp LS(SEMI)      ┃ Shift + ;
 *  * (asterisk)      ┃ &kp LS(SQT)       ┃ Shift + :
 *  < (less than)     ┃ &kp LS(COMMA)     ┃ Shift + ,
 *  > (greater than)  ┃ &kp LS(DOT)       ┃ Shift + .
 *  ? (question)      ┃ &kp LS(SLASH)     ┃ Shift + /
 *  _ (underscore)    ┃ &kp LS(INT1)      ┃ Shift + ろ
 *  { (brace open)    ┃ &kp LS(RBKT)      ┃ Shift + ]  (JISでの物理位置)
 *  } (brace close)   ┃ &kp LS(BSLH)      ┃ Shift + \  (JISでの物理位置)
 * -------------------┃-------------------┃------------------------------------
 *  Shift不要の記号    ┃ ZMK Binding       ┃ Note
 * -------------------┃-------------------┃------------------------------------
 *  @ (at mark)       ┃ &kp LBKT          ┃ [ のキー
 *  [ (bracket open)  ┃ &kp RBKT          ┃ ] のキー
 *  ] (bracket close) ┃ &kp BSLH          ┃ \ のキー
 *  ^ (caret)         ┃ &kp EQUAL         ┃ ^ のキー
 *  : (colon)         ┃ &kp SQT           ┃ : のキー
 *  ; (semicolon)     ┃ &kp SEMI          ┃ ; のキー
 *  \                 ┃ &kp INT1          ┃ 円マーク
 *  '                 ┃ &kp AMPS          ┃ '
 * ============================================================================
 */

    keymap {
        compatible = "zmk,keymap";

        // レイヤー0: 基本レイヤー
        default_layer {
            bindings = <
                           &kp N1    &kp N2     &kp N3     &kp N4     &kp N5                                &kp N6    &kp N7     &kp N8    &kp N9     &kp N0
                &kp ESC    &kp Q     &kp W      &kp E      &kp R      &kp T                     &kp MINUS   &kp Y     &kp U      &kp I     &kp O      &kp P    &kp BSPC
                &kp CAPS   &kp A     &kp S      &kp D      &kp F      &kp G     &kp BSPC        &kp SLASH   &kp H     &kp J      &kp K     &kp L      &kp UP   &kp DEL
                &kp LSHFT  &kp UP    &kp Z      &kp X      &kp C      &kp V     &kp ENTER                   &kp B     &kp N      &kp M     &kp COMMA  &kp DOT  &kp ENTER
                &kp LEFT   &kp DOWN  &kp RIGHT  &kp LCTRL  &kp TAB    &kp LALT  &lt 1 SPACE     &lt 2 INT5  &kp LGUI  &kp RBKT   &kp BSLH
            >;
            sensor-bindings = <&scroll_left_right>;
        };

        // レイヤー1: Upper
        upper_layer {
            bindings = <
                        &kp N6   &kp N7    &kp N8    &kp N9    &kp N9                            &kp CARET     &kp AMPS     &kp ASTRK     &kp LPAR  &kp RPAR 
                &trans  &none    &none     &none     &none     &none                    &kp DEL  &kp LBKT      &kp INT1     &none         &kp RBKT  &kp BSLH   &trans
                &trans  &none    &none     &none     &none     &none      &kp DEL       &trans   &kp LS(INT3)  &none        &kp SEMI      &kp SQT   &trans     &trans
                &trans  &trans   &none     &none     &none     &none      &trans                 &none         &none        &kp LS(INT1)  &trans    &trans     &trans
                &trans  &trans   &trans    &trans    &trans    &trans     &trans        &trans   &trans        &kp LS(SQT)  &kp LS(SEMI)
            >;
            sensor-bindings = <&scroll_left_right>;
        };

        // レイヤー2: Lower
        lower_layer {
            bindings = <
                        &none       &none         &none     &none     &none                            &none   &none   &none   &none   &none
                &trans  &bt BT_CLR  &kp BSLH      &kp N7    &kp N8    &kp N9     &kp DEL     &m_sshot  &trans  &trans  &none   &none   &none   &trans
                &trans  &none       &kp LS(SEMI)  &kp N4    &kp N5    &kp N6     &trans      &m_slock  &trans  &trans  &none   &none   &trans  &trans
                &trans  &trans      &kp N0        &kp N1    &kp N2    &kp N3     &trans                        &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans      &trans        &trans    &trans    &trans     &trans      &trans    &trans  &trans
            >;
            sensor-bindings = <&inc_dec_kp RIGHT LEFT>;
        };
    };
};
